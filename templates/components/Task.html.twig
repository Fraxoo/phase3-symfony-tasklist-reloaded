<turbo-frame id="refresh_content">
	<div class="flex p-4 border justify-between items-center rounded-xl border-[rgb(164,164,166,0.3)]">
		<a href="{{ path('app_john',{id:1}) }}">Revert Done !</a>

		<div class="flex gap-4" {{attributes}}>
			<form action="{{ path('app_john' , {id: task.id})}} " method="GET" class=" relative" >
				<input type="checkbox" class="auto-submit" name="done" value="{{ csrf_token('task_done') }}" data-id="{{task.id}}" id="check-task">
				<button>
					<input type="checkbox" class="auto-submit" name="done" value="{{ csrf_token('task_done') }}" data-id="{{task.id}}" id="check-task">
				</button>
			</form>
			<div>
				<div class="flex gap-4">
					<p class="font-semibold">{{ task.title}}</p>
					<p
						class="px-2 py-1 rounded text-xs font-medium {{task.priority.level == 'urgent'
																					                    ? 'text-red-500 bg-red-100 border border-red-200' : (task.priority.level== 'important'
																					                    ? 'text-yellow-500 bg-yellow-100 border border-yellow-200' : (task.priority.level=='normal'
																					                    ? 'text-blue-500 bg-blue-100 border border-blue-200' : 'text-gray-500 bg-gray-100' ))}}">
						{{
						task.priority.level}}
					</p>
				</div>
				<p class="text-[#7f7f80]">{{task.status.value}}</p>
			</div>
		</div>
		<button data-id="{{ task.id }}" id="pin-btn">
			{% if task.isPinned %}
			<i class="fa-solid fa-thumbtack-slash"></i>
			{% else %}
			<i class="fa-solid fa-thumbtack"></i>
			{% endif %}
		</button>
	</div>
</turbo-frame>